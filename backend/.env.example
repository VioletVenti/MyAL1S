# --- LLM (provider-agnostic; PydanticAI model string) ----------------------
# Default to the latest, most capable Claude. Switch providers/models freely,
# e.g. anthropic:claude-sonnet-4-6 (cheaper) or another provider's model.
MYAL1S_LLM_MODEL=anthropic:claude-opus-4-8

# Your own Anthropic API key (read by the Anthropic SDK). NEVER commit the real
# .env — only this .env.example is tracked.
ANTHROPIC_API_KEY=sk-ant-...

# --- pku3b MCP server -------------------------------------------------------
# Path to the pku3b binary built with the `mcp` feature:
#   (cd ../pku3b && cargo build --release --features mcp)
MYAL1S_PKU3B_BIN=../pku3b/target/release/pku3b

# Optional: override the pku3b config path (cfg.toml). Leave unset to use
# pku3b's default (~/.config/pku3b/cfg.toml). Run `pku3b init` + `pku3b ct` once
# to configure credentials and warm the session before starting the backend.
# MYAL1S_PKU3B_CONFIG=/abs/path/to/cfg.toml
